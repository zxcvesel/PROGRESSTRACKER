PROGRESS_TRACKER_ENV=production
PROGRESS_TRACKER_HOST=0.0.0.0
PROGRESS_TRACKER_PORT=8080
PROGRESS_TRACKER_DB_PATH=/app/data/progress.db
PROGRESS_TRACKER_ALLOWED_ORIGINS=https://progress.example.com
PROGRESS_TRACKER_PUBLIC_URL=https://progress.example.com
PROGRESS_TRACKER_SECURE_COOKIES=true
PROGRESS_TRACKER_TRUST_PROXY=true
PROGRESS_TRACKER_DEV_TIMER_SPEED=false
PROGRESS_TRACKER_DEV_ACTION_TOKENS=false
PROGRESS_TRACKER_SMTP_HOST=smtp.example.com
PROGRESS_TRACKER_SMTP_PORT=587
PROGRESS_TRACKER_SMTP_USERNAME=
PROGRESS_TRACKER_SMTP_PASSWORD=
PROGRESS_TRACKER_SMTP_FROM=no-reply@progress.example.com
