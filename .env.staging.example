PROGRESS_TRACKER_ALLOWED_ORIGINS=https://progress.example.com
PROGRESS_TRACKER_PUBLIC_URL=https://progress.example.com
PROGRESS_TRACKER_SMTP_HOST=smtp.example.com
PROGRESS_TRACKER_SMTP_PORT=587
PROGRESS_TRACKER_SMTP_USERNAME=
PROGRESS_TRACKER_SMTP_PASSWORD=
PROGRESS_TRACKER_SMTP_FROM=no-reply@progress.example.com
PROGRESS_TRACKER_VAPID_SUBJECT=mailto:notifications@progress.example.com
PROGRESS_TRACKER_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
PROGRESS_TRACKER_VAPID_PRIVATE_KEY=replace-with-vapid-private-key
PROGRESS_TRACKER_BACKUP_INTERVAL_SECONDS=86400
PROGRESS_TRACKER_BACKUP_RETENTION_DAYS=14
STAGING_HTTP_PORT=80
STAGING_HTTPS_PORT=443
